{
  "name": "kalink-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --no-server-fast-refresh",
    "dev:s3": "node --env-file=.env.local.s3 ./node_modules/next/dist/bin/next dev --no-server-fast-refresh",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "payload": "payload",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@payloadcms/db-postgres": "3.83.0",
    "@payloadcms/next": "3.83.0",
    "@payloadcms/richtext-lexical": "3.83.0",
    "@payloadcms/storage-s3": "3.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "graphql": "16.11.0",
    "lucide-react": "0.511.0",
    "next": "16.2.4",
    "payload": "3.83.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "6.2.0",
    "sharp": "0.34.4",
    "tailwind-merge": "3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "20.19.39",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "oxfmt": "0.18.0",
    "oxlint": "1.18.0",
    "shadcn": "^4.3.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.20.6",
    "typescript": "6.0.3"
  }
}
